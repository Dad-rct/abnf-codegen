{
  "name": "@pebbletree/abnf-codegen",
  "version": "0.1.2",
  "description": "Type-safe ABNF (RFC 5234) parser/builder code generator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "grammars"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    }
  },
  "bin": {
    "abnf-codegen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "abnf",
    "rfc5234",
    "parser",
    "codegen",
    "sip"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dad-rct/abnf-codegen.git"
  },
  "bugs": {
    "url": "https://github.com/Dad-rct/abnf-codegen/issues"
  },
  "homepage": "https://github.com/Dad-rct/abnf-codegen#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "abnf": "~5.0.4"
  },
  "devDependencies": {
    "@types/node": "~18.19.130",
    "tsx": "~4.21.0",
    "typescript": "~6.0.2",
    "vitest": "~2.1.9"
  }
}